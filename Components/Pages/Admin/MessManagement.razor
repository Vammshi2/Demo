@page "/admin/Mess"
@layout AdminLayout
@attribute [Authorize(Roles = AppRoles.Admin)]
@inject IHostelRepository Repository
@inject AuthenticationStateProvider AuthStateProvider

<DynamicPageTitle Prefix="Mess Management" />

<div class="admin-page-title with-action">
    <div>
        <h1>Food & Mess</h1>
        <p>Plan daily menus and track tenant meal opt-ins</p>
    </div>
    <button class="button primary compact" @onclick="StartCreate"><span aria-hidden="true">+</span> Add Menu</button>
</div>

<div class="admin-metric-grid">
    <article class="admin-metric-card">
        <div>
            <span>Menus Planned</span>
            <strong>@menus.Count</strong>
        </div>
        <span class="metric-icon blue utensils-icon" aria-hidden="true"></span>
    </article>
    <article class="admin-metric-card">
        <div>
            <span>Today's Meals</span>
            <strong>@menus.Count(menu => menu.MenuDate == Today)</strong>
        </div>
        <span class="metric-icon orange utensils-icon" aria-hidden="true"></span>
    </article>
    <article class="admin-metric-card">
        <div>
            <span>Total Opt In</span>
            <strong>@menus.Sum(menu => menu.OptInCount)</strong>
        </div>
        <span class="metric-icon green users-icon" aria-hidden="true"></span>
    </article>
    <article class="admin-metric-card">
        <div>
            <span>Total Opt Out</span>
            <strong>@menus.Sum(menu => menu.OptOutCount)</strong>
        </div>
        <span class="metric-icon red alert-icon" aria-hidden="true"></span>
    </article>
</div>

@if (showForm)
{
    <EditForm Model="form" OnValidSubmit="SaveAsync" FormName="mess-management">
        <DataAnnotationsValidator />
        <div class="admin-panel form-grid admin-form-panel">
            <div class="form-grid two">
                <div class="field">
                    <label>Menu date</label>
                    <InputDate @bind-Value="form.MenuDate" />
                </div>
                <div class="field">
                    <label>Meal type</label>
                    <InputSelect @bind-Value="form.MealType">
                        <option value="breakfast">Breakfast</option>
                        <option value="lunch">Lunch</option>
                        <option value="dinner">Dinner</option>
                    </InputSelect>
                </div>
            </div>
            <div class="field">
                <label>Menu items</label>
                <InputTextArea @bind-Value="form.MenuItems" placeholder="Rice, dal, curry, curd..." />
                <ValidationMessage For="() => form.MenuItems" />
            </div>
            <div class="form-grid two">
                <div class="field">
                    <label>Opt-in count</label>
                    <InputNumber @bind-Value="form.OptInCount" />
                </div>
                <div class="field">
                    <label>Opt-out count</label>
                    <InputNumber @bind-Value="form.OptOutCount" />
                </div>
            </div>
            <div class="actions">
                <button class="button primary" type="submit">Save menu</button>
                <button class="button outline" type="button" @onclick="Cancel">Cancel</button>
            </div>
        </div>
    </EditForm>
}

<div class="admin-filter-row">
    <input class="search-input grow" placeholder="Search menu items..." @bind="search" @bind:event="oninput" />
    <select class="search-input" @bind="mealFilter">
        <option value="all">All Meals</option>
        <option value="breakfast">Breakfast</option>
        <option value="lunch">Lunch</option>
        <option value="dinner">Dinner</option>
    </select>
</div>

@if (!FilteredMenus.Any())
{
    <div class="admin-empty">
        <span class="empty-icon utensils-icon" aria-hidden="true"></span>
        <p>No mess menus planned for this period.</p>
    </div>
}
else
{
    <div class="menu-grid">
        @foreach (var menu in FilteredMenus)
        {
            <article class="admin-panel menu-card">
                <div class="menu-card-head">
                    <div>
                        <span class="eyebrow">@menu.MenuDate.ToString("ddd, dd MMM")</span>
                        <h2>@Label(menu.MealType)</h2>
                    </div>
                    <span class="metric-icon orange utensils-icon" aria-hidden="true"></span>
                </div>
                <p>@menu.MenuItems</p>
                <div class="menu-counts">
                    <span><strong>@menu.OptInCount</strong> opt in</span>
                    <span><strong>@menu.OptOutCount</strong> opt out</span>
                </div>
                <div class="actions">
                    <button class="button outline compact" @onclick="() => StartEdit(menu)">Edit</button>
                    <button class="button danger compact" @onclick="() => DeleteAsync(menu.Id)">Delete</button>
                </div>
            </article>
        }
    </div>
}

@code {
    private readonly DateOnly Today = DateOnly.FromDateTime(DateTime.Today);
    private List<MessMenu> menus = [];
    private MessMenuForm form = new();
    private bool showForm;
    private string search = string.Empty;
    private string mealFilter = "all";

    private IEnumerable<MessMenu> FilteredMenus => menus.Where(menu =>
    {
        var matchesSearch = string.IsNullOrWhiteSpace(search)
            || menu.MenuItems.Contains(search, StringComparison.OrdinalIgnoreCase)
            || menu.MenuDate.ToString("dd MMM yyyy").Contains(search, StringComparison.OrdinalIgnoreCase);
        var matchesMeal = mealFilter == "all" || menu.MealType == mealFilter;
        return matchesSearch && matchesMeal;
    });

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        var from = DateOnly.FromDateTime(DateTime.Today.AddDays(-2));
        var to = DateOnly.FromDateTime(DateTime.Today.AddDays(21));
        menus = await Repository.GetMessMenusAsync(from, to);
    }

    private void StartCreate()
    {
        form = new MessMenuForm { MenuDate = Today };
        showForm = true;
    }

    private void StartEdit(MessMenu menu)
    {
        form = new MessMenuForm
        {
            Id = menu.Id,
            MenuDate = menu.MenuDate,
            MealType = menu.MealType,
            MenuItems = menu.MenuItems,
            OptInCount = menu.OptInCount,
            OptOutCount = menu.OptOutCount
        };
        showForm = true;
    }

    private async Task SaveAsync()
    {
        await Repository.SaveMessMenuAsync(form, await ActorAsync());
        form = new MessMenuForm();
        showForm = false;
        await ReloadAsync();
    }

    private async Task DeleteAsync(Guid id)
    {
        await Repository.DeleteMessMenuAsync(id, await ActorAsync());
        await ReloadAsync();
    }

    private void Cancel()
    {
        form = new MessMenuForm();
        showForm = false;
    }

    private static string Label(string value) => value.Replace("_", " ");

    private async Task<string> ActorAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.Name ?? "admin";
    }
}
