@page "/admin/Maintenance"
@layout AdminLayout
@attribute [Authorize(Roles = AppRoles.Admin)]
@inject IHostelRepository Repository
@inject AuthenticationStateProvider AuthStateProvider

<DynamicPageTitle Prefix="Maintenance" />

<div class="admin-page-title with-action">
    <div>
        <h1>Maintenance Tickets</h1>
        <p>Track tenant issues, assignments, and completion status</p>
    </div>
    <button class="button primary compact" @onclick="StartCreate"><span aria-hidden="true">+</span> New Ticket</button>
</div>

<div class="admin-metric-grid">
    <article class="admin-metric-card">
        <div>
            <span>Open</span>
            <strong>@tickets.Count(ticket => ticket.Status == "open")</strong>
        </div>
        <span class="metric-icon red tool-icon" aria-hidden="true"></span>
    </article>
    <article class="admin-metric-card">
        <div>
            <span>In Progress</span>
            <strong>@tickets.Count(ticket => ticket.Status == "in_progress")</strong>
        </div>
        <span class="metric-icon orange tool-icon" aria-hidden="true"></span>
    </article>
    <article class="admin-metric-card">
        <div>
            <span>Completed</span>
            <strong>@tickets.Count(ticket => ticket.Status == "completed")</strong>
        </div>
        <span class="metric-icon green tool-icon" aria-hidden="true"></span>
    </article>
    <article class="admin-metric-card">
        <div>
            <span>High Priority</span>
            <strong>@tickets.Count(ticket => ticket.Priority == "high" || ticket.Priority == "urgent")</strong>
        </div>
        <span class="metric-icon blue alert-icon" aria-hidden="true"></span>
    </article>
</div>

@if (showForm)
{
    <EditForm Model="form" OnValidSubmit="SaveAsync" FormName="maintenance-management">
        <DataAnnotationsValidator />
        <div class="admin-panel form-grid admin-form-panel">
            <div class="form-grid two">
                <div class="field">
                    <label>Tenant</label>
                    <InputSelect @bind-Value="form.TenantId">
                        <option value="">No tenant selected</option>
                        @foreach (var tenant in tenants)
                        {
                            <option value="@tenant.Id">@tenant.FullName - Room @tenant.Room?.RoomNumber</option>
                        }
                    </InputSelect>
                </div>
                <div class="field">
                    <label>Room</label>
                    <InputSelect @bind-Value="form.RoomId">
                        <option value="">No room selected</option>
                        @foreach (var room in rooms)
                        {
                            <option value="@room.Id">Room @room.RoomNumber</option>
                        }
                    </InputSelect>
                </div>
            </div>
            <div class="form-grid two">
                <div class="field">
                    <label>Title</label>
                    <InputText @bind-Value="form.Title" />
                    <ValidationMessage For="() => form.Title" />
                </div>
                <div class="field">
                    <label>Assigned to</label>
                    <InputText @bind-Value="form.AssignedTo" placeholder="Technician or staff name" />
                </div>
            </div>
            <div class="form-grid two">
                <div class="field">
                    <label>Priority</label>
                    <InputSelect @bind-Value="form.Priority">
                        <option value="low">Low</option>
                        <option value="medium">Medium</option>
                        <option value="high">High</option>
                        <option value="urgent">Urgent</option>
                    </InputSelect>
                </div>
                <div class="field">
                    <label>Status</label>
                    <InputSelect @bind-Value="form.Status">
                        <option value="open">Open</option>
                        <option value="in_progress">In Progress</option>
                        <option value="completed">Completed</option>
                        <option value="cancelled">Cancelled</option>
                    </InputSelect>
                </div>
            </div>
            <div class="field">
                <label>Description</label>
                <InputTextArea @bind-Value="form.Description" />
                <ValidationMessage For="() => form.Description" />
            </div>
            <div class="field">
                <label>Resolution notes</label>
                <InputTextArea @bind-Value="form.ResolutionNotes" />
            </div>
            <div class="actions">
                <button class="button primary" type="submit">Save ticket</button>
                <button class="button outline" type="button" @onclick="Cancel">Cancel</button>
            </div>
        </div>
    </EditForm>
}

<div class="admin-filter-row">
    <input class="search-input grow" placeholder="Search title, tenant, room, or assignee..." @bind="search" @bind:event="oninput" />
    <select class="search-input" @bind="statusFilter">
        <option value="all">All Status</option>
        <option value="open">Open</option>
        <option value="in_progress">In Progress</option>
        <option value="completed">Completed</option>
        <option value="cancelled">Cancelled</option>
    </select>
</div>

@if (!FilteredTickets.Any())
{
    <div class="admin-empty">
        <span class="empty-icon tool-icon" aria-hidden="true"></span>
        <p>No maintenance tickets found.</p>
    </div>
}
else
{
    <div class="admin-panel table-card">
        <div class="table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Issue</th>
                        <th>Tenant</th>
                        <th>Room</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Assigned</th>
                        <th>Opened</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in FilteredTickets)
                    {
                        <tr>
                            <td>
                                <strong>@ticket.Title</strong>
                                <small class="table-subtext">@ticket.Description</small>
                            </td>
                            <td>@(ticket.Tenant?.FullName ?? "Unassigned")</td>
                            <td>@RoomLabel(ticket)</td>
                            <td><span class="badge @PriorityBadge(ticket.Priority)">@Label(ticket.Priority)</span></td>
                            <td><span class="badge @StatusBadge(ticket.Status)">@Label(ticket.Status)</span></td>
                            <td>@(string.IsNullOrWhiteSpace(ticket.AssignedTo) ? "-" : ticket.AssignedTo)</td>
                            <td>@ticket.CreatedUtc.ToString("dd MMM yyyy")</td>
                            <td>
                                <div class="actions">
                                    <button class="button outline compact" @onclick="() => StartEdit(ticket)">Edit</button>
                                    @if (ticket.Status != "completed")
                                    {
                                        <button class="button primary compact" @onclick='() => UpdateStatusAsync(ticket, "completed")'>Complete</button>
                                    }
                                    <button class="button danger compact" @onclick="() => DeleteAsync(ticket.Id)">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<MaintenanceTicket> tickets = [];
    private List<Tenant> tenants = [];
    private List<Room> rooms = [];
    private MaintenanceTicketForm form = new();
    private bool showForm;
    private string search = string.Empty;
    private string statusFilter = "all";

    private IEnumerable<MaintenanceTicket> FilteredTickets => tickets.Where(ticket =>
    {
        var tenantName = ticket.Tenant?.FullName ?? string.Empty;
        var roomNumber = ticket.Room?.RoomNumber ?? ticket.Tenant?.Room?.RoomNumber ?? string.Empty;
        var matchesSearch = string.IsNullOrWhiteSpace(search)
            || ticket.Title.Contains(search, StringComparison.OrdinalIgnoreCase)
            || ticket.Description.Contains(search, StringComparison.OrdinalIgnoreCase)
            || ticket.AssignedTo.Contains(search, StringComparison.OrdinalIgnoreCase)
            || tenantName.Contains(search, StringComparison.OrdinalIgnoreCase)
            || roomNumber.Contains(search, StringComparison.OrdinalIgnoreCase);
        var matchesStatus = statusFilter == "all" || ticket.Status == statusFilter;
        return matchesSearch && matchesStatus;
    });

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        tickets = await Repository.GetMaintenanceTicketsAsync();
        tenants = await Repository.GetTenantsAsync();
        rooms = await Repository.GetRoomsAsync();
    }

    private void StartCreate()
    {
        form = new MaintenanceTicketForm();
        showForm = true;
    }

    private void StartEdit(MaintenanceTicket ticket)
    {
        form = new MaintenanceTicketForm
        {
            Id = ticket.Id,
            TenantId = ticket.TenantId,
            RoomId = ticket.RoomId,
            Title = ticket.Title,
            Description = ticket.Description,
            Priority = ticket.Priority,
            Status = ticket.Status,
            AssignedTo = ticket.AssignedTo,
            ResolutionNotes = ticket.ResolutionNotes
        };
        showForm = true;
    }

    private async Task SaveAsync()
    {
        await Repository.SaveMaintenanceTicketAsync(form, await ActorAsync());
        form = new MaintenanceTicketForm();
        showForm = false;
        await ReloadAsync();
    }

    private async Task UpdateStatusAsync(MaintenanceTicket ticket, string status)
    {
        var quickForm = new MaintenanceTicketForm
        {
            Id = ticket.Id,
            TenantId = ticket.TenantId,
            RoomId = ticket.RoomId,
            Title = ticket.Title,
            Description = ticket.Description,
            Priority = ticket.Priority,
            Status = status,
            AssignedTo = ticket.AssignedTo,
            ResolutionNotes = ticket.ResolutionNotes
        };
        await Repository.SaveMaintenanceTicketAsync(quickForm, await ActorAsync());
        await ReloadAsync();
    }

    private async Task DeleteAsync(Guid id)
    {
        await Repository.DeleteMaintenanceTicketAsync(id, await ActorAsync());
        await ReloadAsync();
    }

    private void Cancel()
    {
        form = new MaintenanceTicketForm();
        showForm = false;
    }

    private static string RoomLabel(MaintenanceTicket ticket)
    {
        var room = ticket.Room?.RoomNumber ?? ticket.Tenant?.Room?.RoomNumber;
        return string.IsNullOrWhiteSpace(room) ? "-" : $"Room {room}";
    }

    private static string PriorityBadge(string priority) => priority switch
    {
        "urgent" => "danger",
        "high" => "warning",
        "medium" => "neutral",
        _ => "success"
    };

    private static string StatusBadge(string status) => status switch
    {
        "completed" => "success",
        "in_progress" => "warning",
        "cancelled" => "neutral",
        _ => "danger"
    };

    private static string Label(string value) => value.Replace("_", " ");

    private async Task<string> ActorAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.Name ?? "admin";
    }
}
