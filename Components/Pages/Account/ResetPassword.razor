@page "/ResetPassword"

<DynamicPageTitle Prefix="Reset Password" />

<section class="section">
    <div class="card auth-card">
        <p class="eyebrow">Reset password</p>
        <h1>Choose a new password</h1>
        <p class="muted">Reset tokens should be validated with ASP.NET Core Identity before changing credentials.</p>
        <form class="form-grid">
            <div class="field">
                <label for="password">New password</label>
                <input id="password" type="password" autocomplete="new-password" required minlength="10" />
            </div>
            <div class="field">
                <label for="confirmPassword">Confirm password</label>
                <input id="confirmPassword" type="password" autocomplete="new-password" required minlength="10" />
            </div>
            <button class="button primary" type="button">Update password</button>
        </form>
    </div>
</section>
