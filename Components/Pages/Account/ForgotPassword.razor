@page "/ForgotPassword"

<DynamicPageTitle Prefix="Forgot Password" />

<section class="section">
    <div class="card auth-card">
        <p class="eyebrow">Account recovery</p>
        <h1>Forgot password</h1>
        <p class="muted">
            Wire this form to your email provider before production. Password reset tokens must be generated server-side.
        </p>
        <form class="form-grid">
            <div class="field">
                <label for="email">Email</label>
                <input id="email" type="email" autocomplete="email" required />
            </div>
            <button class="button primary" type="button">Send reset link</button>
        </form>
    </div>
</section>
