@page
@model HostelPro.LicenseAuthority.Pages.LoginModel
@{
    ViewData["Title"] = "Vendor sign in";
}

<section class="auth-panel">
    <div class="section-heading compact">
        <p class="eyebrow">Vendor access</p>
        <h1>Sign in</h1>
        <p>Manage customer licenses and registered installations.</p>
    </div>
    <form method="post" class="form-stack">
        <div asp-validation-summary="ModelOnly" class="validation"></div>
        <input type="hidden" asp-for="ReturnUrl" />
        <label asp-for="Input.Email"></label>
        <input asp-for="Input.Email" autocomplete="username" />
        <span asp-validation-for="Input.Email" class="field-error"></span>
        <label asp-for="Input.Password"></label>
        <input asp-for="Input.Password" autocomplete="current-password" />
        <span asp-validation-for="Input.Password" class="field-error"></span>
        <label class="checkbox-row">
            <input asp-for="Input.RememberMe" />
            <span>Keep me signed in</span>
        </label>
        <button class="button primary" type="submit">Sign in</button>
    </form>
</section>
